#!/usr/bin/env bash

_dice_err() { printf 'dice: %s\n' "$*" >&2; exit 1; }

# Roll NdM, print result to stdout; exit 1 on invalid expression
_roll() {
    local expr="$1"
    [[ "$expr" =~ ^([0-9]*)d([0-9]+)$ ]] \
        || _dice_err "invalid expression '$expr' (expected NdM or dM, e.g. 1d6 or d6)"
    local n="${BASH_REMATCH[1]:-1}" m="${BASH_REMATCH[2]}"
    [[ "$m" -gt 0 ]] || _dice_err "die must have at least 1 side"
    local total=0 i
    for ((i = 0; i < n; i++)); do
        total=$((total + RANDOM % m + 1))
    done
    printf '%d' "$total"
}

main() {
    [[ $# -gt 0 ]] || {
        printf 'Usage: dice <NdM> [+ <NdM> ...]\n' >&2
        printf 'Examples:\n  dice 1d6\n  dice 1d6 1d12\n  dice 2d6 + 1d4\n' >&2
        exit 1
    }

    # Tokenize: commas are separators; split "1d6+1d8" into ["1d6", "+", "1d8"]
    local tokens=()
    for arg in "$@"; do
        local normalized="${arg//,/ }"
        normalized="${normalized//+/ + }"
        read -ra parts <<< "$normalized"
        for part in "${parts[@]}"; do
            [[ -n "$part" ]] && tokens+=("$part")
        done
    done

    # Group tokens:
    #   '+' joins adjacent dice into the same group (summed together)
    #   space/comma between dice (no '+') = separate groups (shown individually)
    local groups=() current=() prev_plus=false
    for tok in "${tokens[@]}"; do
        if [[ "$tok" == "+" ]]; then
            prev_plus=true
        else
            if [[ "$prev_plus" == true ]]; then
                current+=("$tok")  # join to current group
            else
                [[ ${#current[@]} -gt 0 ]] && groups+=("${current[*]}")
                current=("$tok")   # start new group
            fi
            prev_plus=false
        fi
    done
    [[ ${#current[@]} -gt 0 ]] && groups+=("${current[*]}")

    [[ ${#groups[@]} -gt 0 ]] || _dice_err "no dice expressions found"

    # Roll each group, summing dice within a group
    local results=()
    for group in "${groups[@]}"; do
        local sum=0 die val
        for die in $group; do
            val=$(_roll "$die") || exit 1
            sum=$((sum + val))
        done
        results+=("$sum")
    done

    # Output: "input => r1, r2, ..."
    local result_str
    printf -v result_str '%s, ' "${results[@]}"
    printf '%s => %s\n' "$*" "${result_str%, }"
}

main "$@"
